          "correct": [
            "she",
            "works",
            "in",
            "a",
            "hospital"
          ],
          "explanation": {
            "correct_sentence": "She works in a hospital.",
            "structure_vi": "S + V(s/es) + in/at + nơi chốn",
            "grammar_notes": [
              "✅ Nói về công việc thường xuyên, dùng Hiện tại đơn.",
              "✅ Động từ 'works' thêm 's' vì chủ ngữ là 'She'."
            ],
            "vocab_notes": [
              {
                "word": "hospital",
                "vi": "bệnh viện",
                "ipa": "ˈhɒspɪtl"
              }
